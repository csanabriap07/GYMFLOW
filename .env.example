# Postgres
POSTGRES_USER=gymflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gymflow

# Backend (usa lo anterior para armar la URL; ajustar host si no es Docker)
DATABASE_URL=postgresql://gymflow:changeme@db:5432/gymflow

# JWT (RN-11, RN-12) — generar un secreto real, nunca commitear el real
JWT_SECRET_KEY=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Zona horaria del gimnasio (RN-02, RN-04)
TZ=America/Bogota

ENVIRONMENT=development
